{
	"name": "hig-doctor",
	"version": "0.2.0",
	"type": "module",
	"packageManager": "pnpm@11.1.1",
	"description": "Diagnose Apple HIG skills repositories for schema and content integrity issues",
	"keywords": [
		"agent-skills",
		"apple",
		"doctor",
		"hig",
		"lint"
	],
	"license": "MIT",
	"bin": {
		"hig-doctor": "./src/cli.js"
	},
	"exports": {
		".": "./src/index.js"
	},
	"files": [
		"src",
		"README.md"
	],
	"engines": {
		"node": ">=18"
	},
	"scripts": {
		"doctor": "node src/cli.js",
		"doctor:tui": "node src/cli.js . --tui",
		"test": "node --test tests/doctor.test.js"
	},
	"optionalDependencies": {
		"ink": "^5.2.1",
		"react": "^18.3.1"
	}
}
