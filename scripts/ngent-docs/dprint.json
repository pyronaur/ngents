{
	"$schema": "https://dprint.dev/schemas/v0.json",
	"lineWidth": 100,
	"includes": [
		"bin/**/*.{ts,tsx,cts,mts,js,jsx,cjs,mjs}",
		"src/**/*.{ts,tsx,cts,mts,js,jsx,cjs,mjs}"
	],
	"excludes": ["**/.git/**", "**/node_modules/**"],
	"typescript": {
		"useTabs": true,
		"quoteStyle": "alwaysDouble",
		"semiColons": "prefer",
		"arguments.preferSingleLine": false,
		"arguments.preferHanging": "always",
		"arrayExpression.preferSingleLine": false,
		"importDeclaration.preferSingleLine": false,
		"exportDeclaration.preferSingleLine": false
	},
	"plugins": ["https://plugins.dprint.dev/typescript-0.95.15.wasm"]
}

