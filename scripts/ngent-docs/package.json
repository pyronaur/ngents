{
	"name": "ngent-docs",
	"version": "0.1.0",
	"private": false,
	"type": "module",
	"packageManager": "pnpm@11.1.1",
	"description": "Docs browser and global vector search CLI for ngents.",
	"bin": {
		"docs": "./bin/docs.ts",
		"docs-git-fetch": "./bin/docs-git-fetch.ts",
		"docs-url-file-fetch": "./bin/docs-url-file-fetch.ts"
	},
	"engines": {
		"node": ">=25"
	},
	"scripts": {
		"lint:dprint": "dprint check",
		"lint:oxlint": "oxlint --type-aware --tsconfig tsconfig.json .",
		"lint:dprint:fix": "dprint fmt",
		"lint:oxlint:fix": "oxlint --type-aware --tsconfig tsconfig.json --fix .",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"jscpd:src": "jscpd --config .jscpd.json",
		"jscpd:tests": "jscpd --config .jscpd.tests.json",
		"knip": "knip --production --no-progress",
		"test": "vitest run"
	},
	"dependencies": {
		"commander": "^14.0.1",
		"liquidjs": "^10.25.0",
		"picocolors": "^1.1.1",
		"zod": "^4.1.8"
	},
	"devDependencies": {
		"@types/node": "^24.5.2",
		"dprint": "^0.54.0",
		"jscpd": "^4.0.9",
		"knip": "^6.11.0",
		"oxlint": "^1.62.0",
		"oxlint-plugin-complexity": "^2.1.2",
		"oxlint-plugin-inhuman": "^0.1.9",
		"oxlint-tsgolint": "^0.22.1",
		"typescript": "^5",
		"vitest": "^3.2.4"
	}
}
